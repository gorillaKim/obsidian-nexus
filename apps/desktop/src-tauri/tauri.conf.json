{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri/tauri.conf.json",
  "productName": "Obsidian Nexus",
  "version": "0.1.0",
  "identifier": "com.obsidian-nexus.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "externalBin": [
      "binaries/nexus-mcp-server",
      "binaries/nexus"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Obsidian Nexus",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/gorillaKim/obsidian-nexus/releases/latest/download/latest.json"
      ],
      "pubkey": "PLACEHOLDER_GENERATE_WITH_cargo_tauri_signer_generate"
    }
  }
}
